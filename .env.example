# Frontend base URL (this app / dev server). Prefer VITE_ prefix so Vite exposes them to the client.
VITE_APP_URL=http://localhost:5173

# Backend API base URL (Express server, etc.)
VITE_API_URL=http://localhost:3000

# Optional: same values without VITE_ — merged at build time in vite.config.ts (see loadEnv + define).

# Debug logging — set to "true" to enable verbose console output from all components.
# Copy this file to .env.local and flip to "true" to enable; never commit .env.local.
VITE_DEBUG=false
